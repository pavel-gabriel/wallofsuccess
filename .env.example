# --- Frontend (build-time, PUBLIC = embedded in the static bundle, safe to expose) ---
# Found in Supabase: Project Settings -> API
PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="YOUR-ANON-PUBLIC-KEY"

# Optional: override the GitHub Pages site/base used by astro.config.mjs
# SITE_URL="https://pavel-gabriel.github.io"
# BASE_PATH="/wallofsuccess"

# --- Edge Function secrets (NEVER put these in the frontend or commit them) ---
# Set with: supabase secrets set KEY=value
# RESEND_API_KEY="re_..."
# RESEND_FROM="Wall of Fame <noreply@yourdomain.com>"
# REQUEST_API_KEY="a-long-random-string-the-external-app-must-send"
# PUBLIC_SITE_URL="https://pavel-gabriel.github.io/wallofsuccess"  # used to build the submit link
