---
// Official Endava logo (wordmark + symbol). The dark-background version is used
// because the brand bar sits on the Solid Blue depth gradient. Imported with
// ?url so Astro emits a fingerprinted asset whose path stays correct under any
// base (e.g. /wallofsuccess on GitHub Pages).
import logoDark from '../assets/brand/endava-logo-dark.svg?url';
const { href = '/' } = Astro.props;
---
<a class="brandmark" href={href} aria-label="Endava — Wall of Fame">
  <img class="brandmark-logo" src={logoDark} alt="Endava" />
</a>
